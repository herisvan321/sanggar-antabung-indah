# 📑 LABEL: APP CONFIGURATION
APP_NAME=RustBasic
APP_ENV=local
APP_PORT=4000
APP_HOST=0.0.0.0
APP_URL=http://localhost:4000
VITE_PORT=5173
# Jalankan `openssl rand -base64 32` untuk mendapatkan key baru
APP_KEY=
APP_DEBUG=true
APP_TIMEZONE=Asia/Jakarta
APP_LIMIT_REQUEST=20

# 📑 LABEL: DATABASE CONFIGURATION
# Pilihan: sqlite, mysql
DB_CONNECTION=sqlite
# DB_HOST=127.0.0.1
# DB_PORT=3306
# DB_DATABASE=rustbasic
# DB_USERNAME=root
# DB_PASSWORD=

# 📑 LABEL: SESSION CONFIGURATION
# Pilihan: database, file
SESSION_DRIVER=database

# 📑 LABEL: EMAIL CONFIGURATION
# email config untuk reset password dan lain lain
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME=emailanda@gmail.com
MAIL_PASSWORD=
MAIL_FROM_ADDRESS="emailanda@gmail.com"